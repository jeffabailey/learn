# Copy to .env and fill in the keys for the vendors you actually use.
# Missing keys cause the script to skip that vendor with a note in the CSV.
# Never commit .env. Only commit .env.example.

# ---- Anthropic ----
# Admin API key. Create in the Anthropic Console under Settings > Admin Keys.
# Required scopes: usage:read, cost:read.
ANTHROPIC_ADMIN_KEY=

# ---- OpenAI ----
# Admin (organization) API key. Create at platform.openai.com under
# Settings > Organization > Admin Keys. Project keys WILL NOT WORK.
OPENAI_ADMIN_KEY=

# ---- GitHub Copilot ----
# Personal access token with manage_billing:copilot scope, plus org admin role.
GITHUB_TOKEN=
# Org login (the slug in the URL: https://github.com/<org>).
GITHUB_ORG=
# Per-seat monthly rate in USD. GitHub does not return cost via the API,
# so the script multiplies seats by this rate. As of 2026:
#   Copilot Business = 19, Copilot Enterprise = 39.
# Override if you have negotiated pricing.
GITHUB_COPILOT_SEAT_RATE_USD=19

# ---- Cursor ----
# Team admin API key. Create at cursor.com/team-settings (Team Owner only).
CURSOR_API_KEY=

# ---- Google Gemini ----
# Aggregate usage and spend for the Gemini API are not exposed via a single
# REST endpoint. They roll up through Google Cloud Billing (BigQuery exports)
# or Cloud Monitoring metrics. Set both values below if you want a row in
# the CSV; otherwise the script writes a placeholder note.
GOOGLE_GEMINI_MONTHLY_COST_USD=
GOOGLE_GEMINI_MONTHLY_TOKENS=

# ---- AWS Kiro (and other AWS-billed AI services) ----
# Standard AWS credentials (any profile or role with ce:GetCostAndUsage).
# Leave blank to fall back to your default AWS credential chain
# (e.g. ~/.aws/credentials, IAM Identity Center, or AWS_PROFILE env var).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Cost Explorer service-name filter for Kiro. Verify this string against
# a recent Cost Explorer report in your account; AWS occasionally renames
# services. Common candidates: "Amazon Kiro", "AmazonKiro", "Amazon Q Developer".
AWS_KIRO_SERVICE_NAME=Amazon Kiro

# ---- Output ----
# Where to write the CSV. Defaults to ./ai-tool-usage-YYYY-MM.csv.
OUTPUT_DIR=.
